{
  "_id": "numbered-bulleted-list",
  "version": 1,
  "formName": "gform",
  "description": "",
  "authConfig": {
    "authModule": "anonymous"
  },
  "sections": [
    {
      "type": "addToList",
      "title": "Items entered",
      "summaryName": "Items entered",
      "shortName": "Items $n",
      "description": "$n - ${item}",
      "summaryDescription": "summary",
      "addAnotherQuestion": {
        "id": "addAnother",
        "type": "choice",
        "label": "Do you want to add another item?",
        "format": "yesno"
      },
      "pages": [
        {
          "title": "Item",
          "fields": [
            {
              "id": "item",
              "type": "text",
              "format": "text"
            }
          ]
        }
      ]
    },
    {
      "title": "Items",
      "fields": [
        {
          "id": "dummy",
          "type": "text",
          "label": "Text",
          "format": "text"
        },
        {
          "id": "numberedInfo",
          "type": "info",
          "label": "",
          "infoText": "numbered list: ${numberedList(item)}",
          "infoType": "noformat"
        },
        {
          "id": "bulletedInfo",
          "type": "info",
          "label": "",
          "infoText": "bulleted list: ${bulletedList(item)}",
          "infoType": "noformat"
        }
      ]
    },
    {
      "title": "Secret",
      "includeIf": "${numberedList(item) = '' || bulletedList(item) = ''}",
      "fields": [
        {
          "id": "secret",
          "type": "choice",
          "label": "Secret",
          "choices": [
            {
              "en": "Reveal",
              "value": "reveal"
            },
            {
              "en": "Keep hidden",
              "value": "keepHidden"
            }
          ]
        }
      ]
    }
  ],
  "acknowledgementSection": {
    "fields": []
  },
  "destinations": [
    {
      "id": "transitionToSubmitted",
      "type": "stateTransition",
      "requiredState": "Submitted"
    }
  ]
}
