{
  "_id": "period-between-two-dates-atl-conditional",
  "version": 1,
  "formName": "gform",
  "description": "",
  "authConfig": {
    "authModule": "anonymous"
  },
  "sections": [
    {
      "type": "addToList",
      "title": "Repeating fields",
      "summaryName": "Repeating field added",
      "shortName": "Repeating field",
      "summaryDescription": "Repeating field",
      "description": "$n. ${dateA} - ${dateB}.",
      "addAnotherQuestion": {
        "id": "addAnother",
        "type": "choice",
        "label": "Do you want to add another field?",
        "format": "yesno"
      },
      "pages": [
        {
          "title": "Dates visibility",
          "fields": [
            {
              "id": "dateControl",
              "type": "choice",
              "choices": [
                {
                  "en": "Show both",
                  "value": "showBoth"
                },
                {
                  "en": "Show date A only",
                  "value": "showDateA"
                },
                {
                  "en": "Show date B only",
                  "value": "showDateB"
                },
                {
                  "en": "Hide both",
                  "value": "hideBoth"
                }
              ]
            }
          ]
        },
        {
          "title": "Dates $n",
          "fields": [
            {
              "id": "dateA",
              "includeIf": "${dateControl contains 'showBoth' || dateControl contains 'showDateA'}",
              "type": "date",
              "label": "Date A"
            },
            {
              "id": "dateB",
              "includeIf": "${dateControl contains 'showBoth' || dateControl contains 'showDateB'}",
              "type": "date",
              "label": "Date B"
            },
            {
              "id": "dummy",
              "type": "text",
              "label": "Dummy",
              "format": "text"
            }
          ]
        }
      ]
    },
    {
      "title": "Test",
      "fields": [
        {
          "id": "dummy2",
          "type": "text",
          "format": "text"
        },
        {
          "id": "basicInfo",
          "type": "info",
          "label": "",
          "infoText": "Date A: ${dateA}\n\nDate B: ${dateB}\n\nPeriod: ${period(dateA, dateB)}\n\nTotal months: ${period(dateA, dateB).totalMonths}\n\nTotal year: ${period(dateA, dateB).years}\n\nMonths: ${period(dateA, dateB).months}\n\nDays: ${period(dateA, dateB).days}\n\nSum: ${period(dateA, dateB).sum}",
          "infoType": "noformat"
        }
      ]
    },
    {
      "title": "Secret",
      "includeIf": "${earliestOf(dateA, dateB) before 01012024}",
      "fields": [
        {
          "id": "secret",
          "type": "choice",
          "label": "Secret",
          "choices": [
            {
              "en": "Reveal",
              "value": "reveal"
            },
            {
              "en": "Keep hidden",
              "value": "keepHidden"
            }
          ]
        }
      ]
    }
  ],
  "acknowledgementSection": {
    "title": "Confirmation page",
    "fields": []
  },
  "destinations": [
    {
      "id": "transitionToSubmitted",
      "type": "stateTransition",
      "requiredState": "Submitted"
    }
  ]
}
