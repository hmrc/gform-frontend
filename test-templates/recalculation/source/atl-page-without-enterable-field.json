{
  "_id": "atl-page-without-enterable-field",
  "version": 1,
  "formName": "gform",
  "description": "",
  "authConfig": {
    "authModule": "hmrc"
  },
  "sections": [
    {
      "type": "addToList",
      "title": "Film productions",
      "summaryName": "Film added",
      "shortName": "Film",
      "summaryDescription": "Film",
      "description": "$n. Film",
      "addAnotherQuestion": {
        "id": "filmAddAnother",
        "type": "choice",
        "label": "Do you want to add another Film?",
        "format": "yesno"
      },
