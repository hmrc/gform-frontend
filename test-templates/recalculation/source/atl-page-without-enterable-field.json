        {
          "title": "Film choice?",
          "fields": [
            {
              "id": "filmChoice",
              "type": "choice",
              "choices": [
                "Yes",
                "No"
              ]
            }
          ]
        },
        {
          "includeIf": "${filmChoice contains 1}",
          "title": "Confirm the deduction",
          "fields": [
            {
              "id": "filmDeductionInfo",
              "type": "info",
              "label": "",
              "infoType": "noformat",
              "infoText": "The additional deduction info"
            }
          ]
        }
      ]
    }
  ],
  "acknowledgementSection": {
    "fields": []
  },
  "destinations": [
    {
      "id": "logit",
      "type": "log"
    }
  ]
}
