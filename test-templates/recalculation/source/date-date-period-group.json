{
  "_id": "date-date-period-group",
  "version": 1,
  "formName": "gform",
  "description": "",
  "authConfig": {
    "authModule": "anonymous"
  },
  "sections": [
    {
      "title": "Enter dates for period",
      "fields": [
        {
          "id": "fieldGroup",
          "type": "group",
          "label": "Dates group",
          "format": "horizontal",
          "repeatsMax": 3,
          "fields": [
            {
              "id": "startDate",
              "type": "date",
              "label": "Start Date"
            },
            {
              "id": "endDate",
              "type": "date",
              "label": "End Date"
            }
          ]
        }
      ]
    },
    {
      "title": "Text box Period sum : ${period(startDate,endDate).sum}\n\nPeriod totalMonths : ${period(startDate,endDate).totalMonths}\n\nPeriod years : ${period(startDate,endDate).years}\n\nPeriod months : ${period(startDate,endDate).months}\n\nPeriod days : ${period(startDate,endDate).days}",
      "fields": [
        {
          "id": "textBox",
          "format": "text",
          "type": "text",
          "label": "Submission Reference",
          "value": "${form.submissionReference}"
        }
      ]
    }
  ],
  "acknowledgementSection": {
    "title": "Confirmation page ",
    "showReference": true,
    "fields": []
  },
  "destinations": [
    {
      "id": "transitionToSubmitted",
      "type": "stateTransition",
      "requiredState": "Submitted"
    }
  ]
}
