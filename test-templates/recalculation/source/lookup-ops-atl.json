{
  "_id": "lookup-ops-atl",
  "version": 1,
  "formName": "gform",
  "description": "",
  "authConfig": {
    "authModule": "anonymous"
  },
  "expressions": {
    "sicCodeA": "dataRetrieve.companyRepresentative.sicCode1",
    "sicCodeB": "dataRetrieve.companyRepresentative.sicCode2",
    "sicCodeC": "dataRetrieve.companyRepresentative.sicCode3",
    "sicCodeD": "dataRetrieve.companyRepresentative.sicCode4",
    "countryCode": "nationality.column.CountryCode"
  },
  "sections": [
    {
      "title": "Show / Hide Add To List",
      "fields": [
        {
          "id": "controlAddToList",
          "type": "choice",
          "choices": [
            {
              "en": "Show Add To List",
              "value": "show"
            },
            {
              "en": "Skip Add To List",
              "value": "skip"
            }
          ]
        }
      ]
    },
    {
      "type": "addToList",
      "title": "Repeating fields",
      "includeIf": "${controlAddToList contains 'show'}",
      "summaryName": "Repeating field added",
      "shortName": "Repeating field",
      "summaryDescription": "Repeating field",
      "description": "$n. ${nationality}",
      "addAnotherQuestion": {
        "id": "addAnother",
        "type": "choice",
        "label": "Do you want to add another field?",
        "format": "yesno"
      },
      "pages": [
        {
          "title": "Nationality and company registration number $n",
          "fields": [
            {
              "id": "nationality",
              "type": "text",
              "label": "Nationality",
              "format": "lookup(nationality)"
            },
            {
              "id": "crn",
              "type": "text",
              "label": "Company registration number",
              "format": "companyRegistrationNumber",
              "helpText": "This is 8 characters. For example, 01234567 or AC012345."
            }
          ],
          "dataRetrieve": [
            {
              "type": "companyHouseProfile",
              "id": "companyRepresentative",
              "parameters": {
                "companyNumber": "${crn}"
              }
            }
          ]
        },
        {
          "title": "Test",
          "fields": [
            {
              "id": "dummy",
              "type": "text",
              "format": "text"
            },
            {
              "id": "sicCodeInfo",
              "type": "info",
              "label": "",
              "infoText": [
                {
                  "en": "SicCode 1 - ${getSicDescription(sicCodeA)}\n\nSicCode 2 - ${getSicDescription(sicCodeB)}\n\nSicCode 3 - ${getSicDescription(sicCodeC)}\n\nSicCode D - ${getSicDescription(sicCodeD)}",
                  "includeIf": "${sicCodeA != '' && sicCodeB != '' && sicCodeC != '' && sicCodeD != ''}"
                },
                {
                  "en": "SicCode 1 - ${getSicDescription(sicCodeA)}\n\nSicCode 2 - ${getSicDescription(sicCodeB)}\n\nSicCode 3 - ${getSicDescription(sicCodeC)}",
                  "includeIf": "${sicCodeA != '' && sicCodeB != '' && sicCodeC != ''}"
                },
                {
                  "en": "SicCode 1 - ${getSicDescription(sicCodeA)}\n\nSicCode 2 - ${getSicDescription(sicCodeB)}",
                  "includeIf": "${sicCodeA != '' && sicCodeB != ''}"
                },
                {
                  "en": "SicCode 1 - ${getSicDescription(sicCodeA)}",
                  "includeIf": "${sicCodeA != ''}"
                },
                {
                  "en": "No SicCode found for ${dataRetrieve.companyRepresentative.companyName}"
                }
              ],
              "infoType": "noformat"
            },
            {
              "id": "countryInfo",
              "type": "info",
              "label": "",
              "infoText": "Country code: ${countryCode}, Country: ${getCountry(countryCode)}",
              "infoType": "noformat"
            }
          ]
        },
        {
          "title": "Sic description secret",
          "includeIf": "${substring(getSicDescription(dataRetrieve.companyRepresentative.sicCode1), 0, 5) = '01220'}",
          "fields": [
            {
              "id": "getSicDescriptionSecret",
              "type": "choice",
              "label": "Sic description secret",
              "choices": [
                {
                  "en": "Reveal",
                  "value": "reveal"
                },
                {
                  "en": "Keep hidden",
                  "value": "keepHidden"
                }
              ]
            }
          ]
        },
        {
          "title": "Get country secret",
          "includeIf": "${getCountry(nationality.column.CountryCode) = 'Czech Republic'}",
          "fields": [
            {
              "id": "getCountrySecret",
              "type": "choice",
              "label": "Country secret",
              "choices": [
                {
                  "en": "Reveal",
                  "value": "reveal"
                },
                {
                  "en": "Keep hidden",
                  "value": "keepHidden"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "title": "Outside ATL",
      "fields": [
        {
          "id": "outsideDummy",
          "type": "text",
          "format": "text"
        },
        {
          "id": "sicCodeInfoOutside",
          "type": "info",
          "label": "",
          "infoText": "Sic codes A: ${sicCodeA}, Sic descriptions: ${getSicDescription(sicCodeA)}",
          "infoType": "noformat"
        },
        {
          "id": "countryInfoOutside",
          "type": "info",
          "label": "",
          "infoText": "Country code: ${countryCode}, Country: ${getCountry(countryCode)}",
          "infoType": "noformat"
        }
      ]
    },
    {
      "title": "Secret outside ATL",
      "includeIf": "${getSicDescription(sicCodeA) = ''}",
      "fields": [
        {
          "id": "secretOutsideAtl",
          "type": "text",
          "format": "text"
        }
      ]
    }
  ],
  "acknowledgementSection": {
    "fields": []
  },
  "destinations": [
    {
      "id": "transitionToSubmitted",
      "type": "stateTransition",
      "requiredState": "Submitted"
    }
  ]
}
