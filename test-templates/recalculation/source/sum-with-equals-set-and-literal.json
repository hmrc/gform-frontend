                }
              ]
            },
            {
              "values": [
                {
                  "value": "calculationSetLiteralNumber = ${calculationSetLiteralNumber}"
                }
              ]
            },
            {
              "values": [
                {
                  "value": "calculationLiteralSetNumber = ${calculationLiteralSetNumber}"
                }
              ]
            },
            {
              "values": [
                {
                  "value": "calculationSetLiteralString = ${calculationSetLiteralString}"
                }
              ]
            },
            {
              "values": [
                {
                  "value": "calculationLiteralSetString = ${calculationLiteralSetString}"
                }
              ]
            },
            {
              "values": [
                {
                  "value": "setLiteralNumber = ${setLiteralNumber}"
                }
              ]
            },
            {
              "values": [
                {
                  "value": "literalSetNumber = ${literalSetNumber}"
                }
              ]
            },
            {
              "values": [
                {
                  "value": "setLiteralString = ${setLiteralString}"
                }
              ]
            },
            {
              "values": [
                {
                  "value": "literalSetString = ${literalSetString}"
                }
              ]
            },
            {
              "values": [
                {
                  "value": "amount: ${amount}"
                }
              ]
            },
            {
              "values": [
                {
                  "value": "number: ${number}"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "acknowledgementSection": {
    "title": "Acknowledgement page",
    "fields": []
