{
  "_id": "repeated-section-chain",
  "version": 1,
  "formName": "gform",
  "description": "",
  "authConfig": {
    "authModule": "anonymous"
  },
  "sections": [
    {
      "title": "Page A",
      "fields": [
        {
          "id": "pageA",
          "type": "text",
          "label": "Page A",
          "format": "number"
        }
      ]
    },
    {
      "title": "Page B $n",
      "repeatsMax": "${pageA}",
      "repeatsMin": "${pageA}",
      "fields": [
        {
          "id": "pageB",
          "type": "text",
          "label": "Page B",
          "format": "number"
        }
      ]
    },
    {
      "title": "Page C $n",
      "repeatsMax": "${pageB.sum}",
      "repeatsMin": "${pageB.sum}",
      "fields": [
        {
          "id": "pageC",
          "type": "text",
          "label": "Page C",
          "format": "number"
        }
      ]
    },
    {
      "title": "Page D",
      "includeIf": "${pageC.sum < 5}",
      "fields": [
        {
          "id": "pageD",
          "type": "text",
          "label": "Page D",
          "format": "number"
        }
      ]
    }
  ],
  "acknowledgementSection": {
    "title": "Confirmation page",
    "fields": []
  },
  "destinations": [
    {
      "id": "transitionToSubmitted",
      "type": "stateTransition",
      "requiredState": "Submitted"
    }
  ]
}
