{
  "_id": "atl-outside-reference-count",
  "version": 1,
  "formName": "gform",
  "description": "",
  "authConfig": {
    "authModule": "anonymous"
  },
  "sections": [
    {
      "type": "addToList",
      "title": "Repeating fields",
      "summaryName": "Repeating field added",
      "shortName": "Repeating field",
      "summaryDescription": "Repeating field",
      "description": "$n. ${genre} ${repeatingField}",
      "addAnotherQuestion": {
        "id": "addAnotherField",
        "type": "choice",
        "label": "Do you want to add another field?",
        "format": "yesno"
      },
      "pages": [
        {
          "title": "Genre $n",
          "fields": [
            {
              "id": "genre",
              "type": "choice",
              "choices": [
                {
                  "en": "Film",
                  "value": "film"
                },
                {
                  "en": "Game",
                  "value": "game"
                }
              ]
            }
          ]
        },
        {
          "title": "Repeating field $n",
          "includeIf": "${genre contains 'game'}",
          "fields": [
            {
              "id": "repeatingField",
              "type": "text",
              "format": "text"
            }
          ]
        }
      ]
    },
    {
      "title": "Text",
      "includeIf": "${repeatingField.count > 0}",
      "fields": [
        {
          "id": "test",
          "type": "text",
          "format": "number"
        }
      ]
    }
  ],
  "acknowledgementSection": {
    "fields": []
  },
  "destinations": [
    {
      "id": "transitionToSubmitted",
      "type": "stateTransition",
      "requiredState": "Submitted"
    }
  ]
}
