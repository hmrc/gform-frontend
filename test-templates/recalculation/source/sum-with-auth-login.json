{
  "_id": "sum-with-auth-login",
  "version": 1,
  "formName": "gform",
  "description": "",
  "authConfig": {
    "authModule": "hmrc"
  },
  "expressions": {
    "offset": "if auth.ggLogin then 10 else 20",
    "calculation": "amount + offset"
  },
  "sections": [
    {
      "type": "addToList",
      "title": "Items",
      "summaryName": "Items",
      "shortName": "Item $n",
      "description": "$n - data: ${amount}.",
      "summaryDescription": "Items",
      "addAnotherQuestion": {
        "id": "addAnother",
        "type": "choice",
        "label": "Do you want to add another?",
        "format": "yesno"
      },
      "pages": [
        {
          "title": "Amount",
          "fields": [
            {
              "id": "amount",
              "label": "Amount",
              "type": "text",
              "format": "number"
            }
          ]
        }
      ]
    },
    {
      "title": "Secret",
      "includeIf": "${calculation.sum = '36'}",
      "fields": [
        {
          "id": "secret",
          "type": "choice",
          "choices": [
            {
              "en": "Found",
              "value": "found"
            }
          ]
        }
      ]
    },
    {
      "title": "Result",
      "fields": [
        {
          "id": "dummy",
          "type": "text",
          "label": "Dummy",
          "format": "text"
        },
        {
          "id": "table",
          "type": "table",
          "summaryValue": "Calculations",
          "label": "Calculations",
          "header": [
            {
              "en": "Test"
            }
          ],
          "rows": [
            {
              "values": [
                {
                  "value": "calculation.sum = ${calculation.sum}"
                }
              ]
            },
            {
              "values": [
                {
                  "value": "calculation = ${calculation}"
                }
              ]
            },
            {
              "values": [
                {
                  "value": "amount: ${amount}"
                }
              ]
            },
            {
              "values": [
                {
                  "value": "auth.ggLogin: ${if auth.ggLogin then 'Yes' else 'No'}"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "acknowledgementSection": {
    "title": "Acknowledgement page",
    "fields": []
  },
  "destinations": [
    {
      "id": "transitionToSubmitted",
      "type": "stateTransition",
      "requiredState": "Submitted"
    }
  ]
}
