{
  "_id": "address-lens-visibility-overseas-address",
  "version": 1,
  "formName": "gform",
  "description": "",
  "authConfig": {
    "authModule": "anonymous"
  },
  "expressions": {
    "addressLine1": "uppercase(overseasAddress.line1)"
  },
  "booleanExpressions": {
    "hasAddressZZ": "substring(removeSpaces(overseasAddress.postcode), 0, 2) = 'ZZ'"
  },
  "sections": [
    {
      "title": "Overseas address",
      "fields": [
        {
          "id": "overseasAddress",
          "type": "overseasAddress"
        }
      ]
    },
    {
      "title": "Test",
      "fields": [
        {
          "id": "dummy",
          "type": "text",
          "format": "text"
        },
        {
          "id": "line1Info",
          "type": "info",
          "label": "",
          "infoText": "Line 1: ${addressLine1}",
          "infoType": "noformat"
        }
      ]
    },
    {
      "title": "Secret",
      "includeIf": "${hasAddressZZ}",
      "fields": [
        {
          "id": "secret",
          "type": "choice",
          "label": "Secret",
          "choices": [
            {
              "en": "Reveal",
              "value": "reveal"
            },
            {
              "en": "Keep hidden",
              "value": "keepHidden"
            }
          ]
        }
      ]
    }
  ],
  "acknowledgementSection": {
    "fields": []
  },
  "destinations": [
    {
      "id": "transitionToSubmitted",
      "type": "stateTransition",
      "requiredState": "Submitted"
    }
  ]
}
